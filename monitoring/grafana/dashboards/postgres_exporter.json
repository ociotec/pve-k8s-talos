    {
      "id": 4,
      "title": "Cache hit ratio",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "100 * sum(pg_stat_database_blks_hit{container=\"postgres-exporter\",namespace=\"$namespace\",app=\"$postgres_instance\",datname!~\"template0|template1\"}) / clamp_min(sum(pg_stat_database_blks_hit{container=\"postgres-exporter\",namespace=\"$namespace\",app=\"$postgres_instance\",datname!~\"template0|template1\"}) + sum(pg_stat_database_blks_read{container=\"postgres-exporter\",namespace=\"$namespace\",app=\"$postgres_instance\",datname!~\"template0|template1\"}), 1)",
          "legendFormat": "hit ratio",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 98
              }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      }
    },
