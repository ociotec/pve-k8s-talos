      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (namespace,pod,container,run) (label_replace((container_memory_working_set_bytes{namespace=~\"${section:raw}\",container=~\"${container:regex}\",container!=\"\",container!=\"POD\",id!=\"\"} or container_memory_usage_bytes{namespace=~\"${section:raw}\",container=~\"${container:regex}\",container!=\"\",container!=\"POD\",id!=\"\"}), \"run\", \"$1\", \"id\", \".*/(.{12}).*$\") and on(namespace) kube_namespace_status_phase{namespace=~\"${namespace:regex}\",phase=\"Active\"})",
          "legendFormat": "usage {{namespace}}/{{pod}} ({{run}})",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum by (namespace,pod,container) (kube_pod_container_resource_requests{namespace=~\"${section:raw}\",container=~\"${container:regex}\",resource=\"memory\"} and on(namespace) kube_namespace_status_phase{namespace=~\"${namespace:regex}\",phase=\"Active\"})",
          "legendFormat": "request {{namespace}}/{{pod}}",
