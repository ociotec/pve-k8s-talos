{
  "title": "Tempo internal metrics",
  "uid": "tempo-internal-metrics",
  "tags": ["infrastructure", "monitoring", "tempo", "tracing"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"}
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(up{app=\"tempo\"}, namespace)",
        "query": {"query": "label_values(up{app=\"tempo\"}, namespace)", "refId": "A"},
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {"selected": false, "text": "monitoring", "value": "monitoring"}
      },
      {
        "name": "pod",
        "label": "Pod",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(up{app=\"tempo\",namespace=~\"$namespace\"}, pod)",
        "query": {"query": "label_values(up{app=\"tempo\",namespace=~\"$namespace\"}, pod)", "refId": "A"},
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {"selected": false, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Target up", "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"editorMode": "code", "expr": "min(up{app=\"tempo\",namespace=~\"$namespace\",pod=~\"$pod\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "wideLayout": true}
    },
    {
      "id": 2, "title": "Trace ingest rate", "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"editorMode": "code", "expr": "sum(rate(tempo_distributor_spans_received_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "color": {"mode": "palette-classic"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "wideLayout": true}
    },
    {
      "id": 3, "title": "Discarded spans", "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"editorMode": "code", "expr": "sum(increase(tempo_discarded_spans_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__range]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 100}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "wideLayout": true}
    },
    {
      "id": 4, "title": "Metrics-generator active series", "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"editorMode": "code", "expr": "sum(tempo_metrics_generator_registry_active_series{namespace=~\"$namespace\",pod=~\"$pod\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "wideLayout": true}
    },
    {
      "id": 5, "title": "Tempo PVC used", "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"editorMode": "code", "expr": "100 * max(kubelet_volume_stats_used_bytes{namespace=~\"$namespace\",persistentvolumeclaim=\"tempo-data\"}) / clamp_min(max(kubelet_volume_stats_capacity_bytes{namespace=~\"$namespace\",persistentvolumeclaim=\"tempo-data\"}), 1)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 75}, {"color": "red", "value": 90}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "wideLayout": true}
    },
    {
      "id": 18, "title": "Tempo pod restarts", "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"editorMode": "code", "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\",pod=~\"$pod\",container=\"tempo\"}[$__range]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "wideLayout": true}
    },
    {
      "id": 6, "title": "Distributor ingestion", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"editorMode": "code", "expr": "sum(rate(tempo_distributor_spans_received_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "spans/s", "refId": "A"},
        {"editorMode": "code", "expr": "sum(rate(tempo_distributor_bytes_received_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "bytes/s", "refId": "B"},
        {"editorMode": "code", "expr": "sum(tempo_distributor_queue_length{namespace=~\"$namespace\",pod=~\"$pod\"})", "legendFormat": "queue", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "unit": "ops"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 7, "title": "Distributor push latency", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"editorMode": "code", "expr": "histogram_quantile(0.99, sum by (le) (rate(tempo_distributor_push_duration_seconds_bucket{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval])))", "legendFormat": "p99", "refId": "A"},
        {"editorMode": "code", "expr": "histogram_quantile(0.50, sum by (le) (rate(tempo_distributor_push_duration_seconds_bucket{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval])))", "legendFormat": "p50", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "unit": "s"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 8, "title": "Discarded spans by reason", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"editorMode": "code", "expr": "sum by (reason) (rate(tempo_discarded_spans_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "{{reason}}", "refId": "A"},
        {"editorMode": "code", "expr": "sum by (reason) (rate(tempo_metrics_generator_spans_discarded_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "generator {{reason}}", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "unit": "ops"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 9, "title": "Ingester pressure", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"editorMode": "code", "expr": "sum(tempo_ingester_live_traces{namespace=~\"$namespace\",pod=~\"$pod\"})", "legendFormat": "live traces", "refId": "A"},
        {"editorMode": "code", "expr": "sum(tempo_ingester_live_trace_bytes{namespace=~\"$namespace\",pod=~\"$pod\"})", "legendFormat": "live trace bytes", "refId": "B"},
        {"editorMode": "code", "expr": "sum(tempo_ingester_flush_queue_length{namespace=~\"$namespace\",pod=~\"$pod\"})", "legendFormat": "flush queue", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "unit": "short"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 10, "title": "Ingester flushes", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"editorMode": "code", "expr": "sum(rate(tempo_ingester_blocks_flushed_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "blocks flushed/s", "refId": "A"},
        {"editorMode": "code", "expr": "sum(rate(tempo_ingester_failed_flushes_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "failed flushes/s", "refId": "B"},
        {"editorMode": "code", "expr": "sum(rate(tempo_ingester_flush_retries_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "retries/s", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "unit": "ops"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 11, "title": "Metrics-generator processing", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"editorMode": "code", "expr": "sum(rate(tempo_metrics_generator_spans_received_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "received spans/s", "refId": "A"},
        {"editorMode": "code", "expr": "sum(tempo_metrics_generator_processor_local_blocks_live_traces{namespace=~\"$namespace\",pod=~\"$pod\"})", "legendFormat": "local-block live traces", "refId": "B"},
        {"editorMode": "code", "expr": "sum(tempo_metrics_generator_processor_local_blocks_flush_queue_size{namespace=~\"$namespace\",pod=~\"$pod\"})", "legendFormat": "local-block flush queue", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "unit": "ops"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 12, "title": "Metrics-generator cardinality", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"editorMode": "code", "expr": "sum(tempo_metrics_generator_registry_active_series{namespace=~\"$namespace\",pod=~\"$pod\"})", "legendFormat": "active series", "refId": "A"},
        {"editorMode": "code", "expr": "sum(tempo_metrics_generator_registry_max_active_series{namespace=~\"$namespace\",pod=~\"$pod\"})", "legendFormat": "max active series", "refId": "B"},
        {"editorMode": "code", "expr": "sum(rate(tempo_metrics_generator_registry_series_limited_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "limited series/s", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "unit": "short"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 13, "title": "TraceQL query frontend", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"editorMode": "code", "expr": "sum by (type) (rate(tempo_query_frontend_queries_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "{{type}} queries/s", "refId": "A"},
        {"editorMode": "code", "expr": "sum(rate(tempo_query_frontend_bytes_inspected_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "inspected bytes/s", "refId": "B"},
        {"editorMode": "code", "expr": "sum(tempo_query_frontend_queue_length{namespace=~\"$namespace\",pod=~\"$pod\"})", "legendFormat": "queue", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "unit": "ops"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 14, "title": "Tempo PVC usage", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"editorMode": "code", "expr": "kubelet_volume_stats_used_bytes{namespace=~\"$namespace\",persistentvolumeclaim=\"tempo-data\"}", "legendFormat": "used", "refId": "A"},
        {"editorMode": "code", "expr": "kubelet_volume_stats_available_bytes{namespace=~\"$namespace\",persistentvolumeclaim=\"tempo-data\"}", "legendFormat": "available", "refId": "B"},
        {"editorMode": "code", "expr": "kubelet_volume_stats_capacity_bytes{namespace=~\"$namespace\",persistentvolumeclaim=\"tempo-data\"}", "legendFormat": "capacity", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "unit": "bytes"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 15, "title": "Tempo pod CPU", "type": "timeseries", "gridPos": {"h": 8, "w": 6, "x": 12, "y": 36},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"editorMode": "code", "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\",pod=~\"$pod\",container=\"tempo\"}[$__rate_interval]))", "legendFormat": "usage {{pod}}", "refId": "A"},
        {"editorMode": "code", "expr": "sum by (pod) (kube_pod_container_resource_requests{namespace=~\"$namespace\",pod=~\"$pod\",container=\"tempo\",resource=\"cpu\"})", "legendFormat": "request {{pod}}", "refId": "B"},
        {"editorMode": "code", "expr": "sum by (pod) (kube_pod_container_resource_limits{namespace=~\"$namespace\",pod=~\"$pod\",container=\"tempo\",resource=\"cpu\"})", "legendFormat": "limit {{pod}}", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "unit": "cores"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 16, "title": "Tempo pod memory", "type": "timeseries", "gridPos": {"h": 8, "w": 6, "x": 18, "y": 36},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"editorMode": "code", "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"$namespace\",pod=~\"$pod\",container=\"tempo\"})", "legendFormat": "usage {{pod}}", "refId": "A"},
        {"editorMode": "code", "expr": "sum by (pod) (kube_pod_container_resource_requests{namespace=~\"$namespace\",pod=~\"$pod\",container=\"tempo\",resource=\"memory\"})", "legendFormat": "request {{pod}}", "refId": "B"},
        {"editorMode": "code", "expr": "sum by (pod) (kube_pod_container_resource_limits{namespace=~\"$namespace\",pod=~\"$pod\",container=\"tempo\",resource=\"memory\"})", "legendFormat": "limit {{pod}}", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "unit": "bytes"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 17, "title": "Build info", "type": "table", "gridPos": {"h": 8, "w": 24, "x": 0, "y": 44},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"editorMode": "code", "expr": "tempo_build_info{namespace=~\"$namespace\",pod=~\"$pod\"}", "format": "table", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "cellOptions": {"type": "auto"}, "inspect": false}, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []},
      "options": {"cellHeight": "sm", "showHeader": true, "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false}}
    }
  ]
}
