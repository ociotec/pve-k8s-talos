      "pluginVersion": "12.4.0-20648027705",
      "targets": [
        {
          "editorMode": "code",
          "expr": "((\n  100 * (1 - avg by(nodename) (\n  rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[5m])\n    * on(instance) group_left(nodename) max by(instance,nodename) (node_uname_info{job=\"node-exporter\"})\n))\n)\nor on(nodename)\n(\n  100 * (max by(nodename) (label_replace(kube_node_info, \"nodename\", \"$1\", \"node\", \"(.*)\")) unless on(nodename) (max by(nodename) (label_replace(up{job=\"node-exporter\"} == 1, \"nodename\", \"$1\", \"node\", \"(.*)\")) and on(nodename) max by(nodename) (label_replace(kube_node_status_condition{condition=\"Ready\",status=\"true\"} == 1, \"nodename\", \"$1\", \"node\", \"(.*)\"))))\n))\n  * on(nodename) group_left() max by(nodename) (label_replace(kube_node_role{role=~\"control-plane|master\"}, \"nodename\", \"$1\", \"node\", \"(.*)\"))",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ],
      "title": "",
      "type": "stat"
    },
